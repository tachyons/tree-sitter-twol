{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "twol",
      "camelcase": "Twol",
      "title": "Twol",
      "scope": "source.twol",
      "file-types": [
        "twol"
      ],
      "injection-regex": "^twol$",
      "class-name": "TreeSitterTwol",
      "highlights": "queries/highlights.scm"
    }
  ],
  "metadata": {
